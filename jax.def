BootStrap: docker
From: python:3.13.5-slim-bookworm
# BootStrap: local
# From: jax.sif

%environment
    # setting environment variable to reduce image size
    export PYTHONDONTWRITEBYTECODE=1

%post
    apt update && apt-get install -y --no-install-recommends git
    pip3 install tqdm --no-compile --no-cache-dir
    pip3 install albumentationsx>=2.0.10 --no-compile --no-cache-dir
    pip3 install "jax[cuda12]">=0.7.1 --no-compile --no-cache-dir
    pip3 install flax>=0.12.0 --no-compile --no-cache-dir
    pip3 install optax>=0.2.5 --no-compile --no-cache-dir
    pip3 install orbax-checkpoint>=0.11.23 --no-compile --no-cache-dir
    pip3 install jaxopt>=0.8.5 --no-compile --no-cache-dir
    # pip3 install tensorflow_probability==0.25.0 --no-compile --no-cache-dir
    pip3 install tfp-nightly --no-compile --no-cache-dir
    pip3 install hydra-core==1.3.2 --no-compile --no-cache-dir
    pip3 install grain>=0.2.12 --no-compile --no-cache-dir
    # pip3 install gemma --no-compile --no-cache-dir
    pip3 install kagglehub --no-compile --no-cache-dir
    pip3 install opencv-python-headless --no-compile --no-cache-dir
    pip3 install "mlflow>=3.10" "sqlalchemy>=2.0,<3" --no-compile --no-cache-dir
%runscript
    # the following command will be invoked when calling the Apptainer image. For example:
    # >> apptainer shell --nv jax.sif
    # >> python3
    # OR
    # >> apptainer exec --nv -B /data_path:/data_path jax.sif python3 "main.py"
    python3


%help
    This container consists of Jax and its derivatives for machine learning research.
    To build a container with this definition:
        >> apptainer build <container_name>.sif <definition_filename>.def
    To get into the interactive mode:
        >> apptainer shell <container_name>.sif
    To run the apptainer:
        >> apptainer exec --nv -B /data_path:/data_path --no-home <container_name>.sif python3 "main.py"